{
	"name": "pi-extensions",
	"license": "MIT",
	"private": true,
	"type": "module",
	"packageManager": "pnpm@10.15.1",
	"scripts": {
		"typecheck": "tsc -p tsconfig.json --noEmit",
		"typecheck:watch": "tsc -p tsconfig.json --noEmit --watch",
		"lint": "biome check --write .",
		"format": "biome format .",
		"format:write": "biome format --write .",
		"test": "vitest run --config utils/vitest.config.ts",
		"test:watch": "vitest --config utils/vitest.config.ts",
		"test:coverage": "vitest run --config utils/vitest.config.ts --coverage"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.4",
		"@mariozechner/pi-agent-core": "^0.63.1",
		"@mariozechner/pi-ai": "^0.64.0",
		"@mariozechner/pi-coding-agent": "^0.64.0",
		"@mariozechner/pi-tui": "^0.64.0",
		"@sinclair/typebox": "^0.34.41",
		"@types/node": "^25.3.1",
		"@vitest/coverage-v8": "^4.0.18",
		"typescript": "^5.9.3",
		"vitest": "^4.0.18"
	},
	"dependencies": {
		"@xterm/addon-serialize": "^0.13.0",
		"@xterm/headless": "^5.5.0",
		"glimpseui": "^0.6.2",
		"node-pty": "^1.1.0"
	}
}
