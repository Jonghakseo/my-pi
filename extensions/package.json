{
	"name": "pi-extensions",
	"private": true,
	"type": "module",
	"packageManager": "pnpm@10.15.1",
	"scripts": {
		"typecheck": "tsc -p tsconfig.json --noEmit",
		"typecheck:watch": "tsc -p tsconfig.json --noEmit --watch",
		"lint": "biome check --write .",
		"format": "biome format .",
		"format:write": "biome format --write .",
		"test": "vitest run --config utils/vitest.config.ts",
		"test:watch": "vitest --config utils/vitest.config.ts"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.4",
		"@mariozechner/pi-agent-core": "^0.55.1",
		"@mariozechner/pi-ai": "^0.55.1",
		"@mariozechner/pi-coding-agent": "^0.55.1",
		"@mariozechner/pi-tui": "^0.55.1",
		"@sinclair/typebox": "^0.34.41",
		"@types/node": "^25.3.1",
		"typescript": "^5.9.3",
		"vitest": "^4.0.18"
	}
}
